# Public contact info, injected at build/request time (see README).
PHONE=123
EMAIL=abc@email.com

# --- "Ask my resume" AI chat (all optional, server-only — never NEXT_PUBLIC_). ---
# When ANY of the three below is unset, the chat feature self-disables: the
# header button is not rendered and /api/chat returns 503. Leave unset for
# local dev / CI; set all three in Vercel to enable the feature.
ANTHROPIC_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
